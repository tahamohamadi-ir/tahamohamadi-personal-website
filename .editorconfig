root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{ps1,bat,cmd}]
end_of_line = crlf

[*.{java,xml,yml,yaml,json,js,ts,vue,css,scss,sql}]
indent_style = space
indent_size = 2

[*.java]
indent_size = 4
